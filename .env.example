# DataDealer Environment Variables
# ─────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file and rename it to ".env" (no .example)
#   2. Fill in your real values below
#   3. Never share or commit the .env file — it contains secrets
# ─────────────────────────────────────────────────────────────

# Your Anthropic API key (get it from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# The email address of the dedicated DataDealer Gmail inbox
GMAIL_INBOX_EMAIL=datarequests@yourfirm.com

# The human consultant who receives forwarded uncertain requests.
# All requests that can't be auto-fulfilled will be emailed here with full context.
CONSULTANT_EMAIL=consultant@yourfirm.com

# Paths to Gmail credential files (you'll create these in setup)
GMAIL_CREDENTIALS_FILE=credentials/credentials.json
GMAIL_TOKEN_FILE=credentials/token.json

# Where uploaded files are stored
UPLOAD_FOLDER=uploads

# Path to the SQLite database file
DATABASE_PATH=database/datadealer.db

# How often to check Gmail for new emails (in minutes)
POLL_INTERVAL_MINUTES=5

# Minimum similarity score (0.0–1.0) to consider a file a candidate match at all
SIMILARITY_THRESHOLD=0.65

# Score above which a match is confident enough to auto-send (must also be approved + high parse confidence)
HIGH_CONFIDENCE_THRESHOLD=0.82

# Password to access admin-only dashboard pages (Upload, Permissions, Config)
# Leave blank to disable authentication (local dev only — do not do this in production)
ADMIN_PASSWORD=change-this-to-a-strong-password

# A random secret key for Flask session security
# Generate one by running: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-string

# Email address to notify when a request enters the pending_clarification queue.
# When CR routing is enabled and the sender's region is unknown, DataDealer sends
# a clarification email to the sender and puts the request on hold. This address
# will receive a brief notification so someone knows to keep an eye on it.
# Leave blank to disable queue notifications.
# NOTIFICATION_EMAIL=ops@yourfirm.com
