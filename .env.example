# DataDealer Environment Variables
# ─────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file and rename it to ".env" (no .example)
#   2. Fill in your real values below
#   3. Never share or commit the .env file — it contains secrets
# ─────────────────────────────────────────────────────────────

# Your Anthropic API key (get it from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# The email address of the dedicated DataDealer Gmail inbox
GMAIL_INBOX_EMAIL=datarequests@yourfirm.com

# Paths to Gmail credential files (you'll create these in setup)
GMAIL_CREDENTIALS_FILE=credentials/credentials.json
GMAIL_TOKEN_FILE=credentials/token.json

# Where uploaded files are stored
UPLOAD_FOLDER=uploads

# Path to the SQLite database file
DATABASE_PATH=database/datadealer.db

# How often to check Gmail for new emails (in minutes)
POLL_INTERVAL_MINUTES=5

# Minimum similarity score (0.0 to 1.0) to auto-match a file to a request
# 0.65 is a good starting point — raise it to be more strict, lower to be more lenient
SIMILARITY_THRESHOLD=0.65

# A random secret key for Flask session security
# Generate one by running: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-string
